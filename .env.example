# ============================================
# CONFIGURATION BASE DE DONNÉES PostgreSQL
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=si_expert_db
DB_USER=postgres
DB_PASSWORD=password

# ============================================
# CONFIGURATION SERVEUR SPRING
# ============================================
SERVER_PORT=8080
SPRING_PROFILE=dev

# ============================================
# CONFIGURATION API TIERS (RapidAPI - TecDoc)
# ============================================
RAPIDAPI_KEY=votre_cle_api_rapidapi
RAPIDAPI_HOST=votre_host_api_rapidapi

# ============================================
# CONFIGURATION FRONTEND REACT
# ============================================
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_ENV=development

# ============================================
# CONFIGURATION UPLOAD FICHIERS
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ============================================
# CONFIGURATION JWT (si utilisé)
# ============================================
JWT_SECRET=votre_secret_jwt_tres_complex_et_long_a_generer_correctement
JWT_EXPIRATION=86400000

# ============================================
# CONFIGURATION MAIL (optionnel)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre_email@gmail.com
MAIL_PASSWORD=votre_mot_de_passe_app
MAIL_FROM=noreply@si-expert.com

# ============================================
# CONFIGURATION LOGS
# ============================================
LOG_LEVEL=INFO
